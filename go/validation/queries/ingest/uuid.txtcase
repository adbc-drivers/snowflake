// part: metadata

[tags]
sql-type-name = "UUID"

// part: input_schema

{
    "format": "+s",
    "children": [
        {
            "name": "idx",
            "format": "l",
            "flags": ["nullable"]
        },
        {
            "name": "value",
            "format": "w:16",
            "flags": ["nullable"],
            "metadata": {
                "ARROW:extension:name": "arrow.uuid"
            }
        }
    ]
}

// part: input

{"idx": 0, "value": null}
{"idx": 1, "value": "AAAAAAAAAAAAAAAAAAAAAA=="}
{"idx": 2, "value": "ASNFZ4mrze8BI0VniavN7w=="}
{"idx": 3, "value": "bKf0puTkT9idTG4vLfSn4Q=="}
{"idx": 4, "value": "/////////////////////w=="}

// part: expected_schema
// The arrow.uuid column is ingested as a native Snowflake UUID column, and
// reading it back yields the arrow.uuid extension type again.
{
    "format": "+s",
    "children": [
        {
            "name": "idx",
            "format": "l",
            "flags": ["nullable"]
        },
        {
            "name": "value",
            "format": "w:16",
            "flags": ["nullable"],
            "metadata": {
                "ARROW:extension:name": "arrow.uuid"
            }
        }
    ]
}

// part: expected

{"idx": 0, "value": null}
{"idx": 1, "value": "AAAAAAAAAAAAAAAAAAAAAA=="}
{"idx": 2, "value": "ASNFZ4mrze8BI0VniavN7w=="}
{"idx": 3, "value": "bKf0puTkT9idTG4vLfSn4Q=="}
{"idx": 4, "value": "/////////////////////w=="}
