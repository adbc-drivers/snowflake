// part: metadata

[setup]
drop = "TEST_UUID_BIND"

[tags]
sql-type-name = "UUID"

// part: setup_query

CREATE TABLE TEST_UUID_BIND (
    IDX INTEGER,
    RES UUID
);

// part: bind_query

INSERT INTO TEST_UUID_BIND VALUES ($1, $2)

// part: bind_schema

{
    "format": "+s",
    "children": [
        {
            "name": "IDX",
            "format": "l",
            "flags": ["nullable"]
        },
        {
            "name": "RES",
            "format": "w:16",
            "flags": ["nullable"],
            "metadata": {
                "ARROW:extension:name": "arrow.uuid"
            }
        }
    ]
}

// part: bind

{"IDX": 1, "RES": null}
{"IDX": 2, "RES": "AAAAAAAAAAAAAAAAAAAAAA=="}
{"IDX": 3, "RES": "ASNFZ4mrze8BI0VniavN7w=="}
{"IDX": 4, "RES": "bKf0puTkT9idTG4vLfSn4Q=="}
{"IDX": 5, "RES": "/////////////////////w=="}

// part: query

SELECT RES FROM TEST_UUID_BIND ORDER BY IDX ASC

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "RES",
            "format": "w:16",
            "flags": ["nullable"],
            "metadata": {
                "ARROW:extension:name": "arrow.uuid"
            }
        }
    ]
}

// part: expected

{"RES": null}
{"RES": "AAAAAAAAAAAAAAAAAAAAAA=="}
{"RES": "ASNFZ4mrze8BI0VniavN7w=="}
{"RES": "bKf0puTkT9idTG4vLfSn4Q=="}
{"RES": "/////////////////////w=="}
